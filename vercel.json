{
  "version": 2,
  "buildCommand": "cd server && npm install && cd ../client && npm install && npm run build",
  "outputDirectory": "client/build",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index?__path=:path*" },
    { "source": "/internal/:path*", "destination": "/api/index?__path=internal/:path*" },
    { "source": "/((?!api/|internal/).*)", "destination": "/index.html" }
  ]
}
