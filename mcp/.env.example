# mcp/.env.example — required environment variables for the Rendezvous MCP server
#
# Copy to .env and fill in values before running.

# Port the MCP server listens on (default 3002)
MCP_PORT=3002

# Supabase — same values as server/.env
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — same value as server/.env (used for itinerary generation via shared utils)
ANTHROPIC_API_KEY=

# Google OAuth — same values as server/.env (used for calendar operations via shared utils)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps — same value as server/.env (used for venue enrichment via shared utils)
GOOGLE_MAPS_API_KEY=

# Main Rendezvous app URL (for OAuth consent redirect)
RENDEZVOUS_APP_URL=https://rendezvous-gamma.vercel.app

# Main server URL for internal HTTP calls (e.g. itinerary generation)
RENDEZVOUS_API_URL=http://localhost:3001

# Shared secret for server-to-server calls (MCP → main server internal API)
RENDEZVOUS_API_KEY=

# Personal dev key — bypasses OAuth, maps to MCP_OWNER_USER_ID.
# NEVER use in production. Logs a warning on every request.
MCP_API_KEY=
MCP_OWNER_USER_ID=

# Comma-separated CORS origins allowed to connect (production)
MCP_ALLOWED_ORIGINS=

# Secret for signing OAuth access tokens (use a random 64+ char string)
JWT_SECRET=
